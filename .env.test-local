# ══════════════════════════════════════════════════════════════════════════════
# .env.test-local
# Profilo di test — probe runtime sulla stessa macchina del monitor
# ══════════════════════════════════════════════════════════════════════════════

PROBE_NODE_ID=test-local-01
ADMIN_TOKEN=change-me-admin
HTTP_PORT=8080

# Broker ActiveMQ embedded in concern-backend
# Ora raggiungibile via nome container grazie alla rete condivisa
BROKER_URL=tcp://concern-backend:61616
BROKER_USER=system
BROKER_PASSWORD=manager

# MySQL nel container concern-mysql
MYSQL_HOST=concern-mysql
MYSQL_PORT=3306
MYSQL_DATABASE=eventdb
MYSQL_USER=concern
MYSQL_PASSWORD=un53cur3!!

# Nome della rete Docker del monitor.
# Scoprilo con: docker network ls | grep concern
# Esempi comuni:
#   concern_monitoring_infrastructure_concern-network
#   concern_concern-network
# Imposta il valore corretto qui:
CONCERN_NETWORK=concern_monitoring_infrastructure_concern-network
