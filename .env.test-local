# ══════════════════════════════════════════════════════════════════════════════
# .env.test-local
#
# Profilo di test per eseguire concern-probes-runtime sulla STESSA macchina
# dove gira Concern_Monitoring_Infrastructure.
#
# Il monitor ha un broker ActiveMQ EMBEDDED sulla porta 61616 e si connette
# a un MySQL locale sulla porta 3306.
# Questo file fa puntare il container probe direttamente a quei servizi
# dell'host tramite host.docker.internal.
#
# Uso:
#   docker compose --env-file .env.test-local -f docker-compose.test-local.yml up --build
#   oppure:
#   ./scripts/start.sh --profile test-local
# ══════════════════════════════════════════════════════════════════════════════

# ── Identity ──────────────────────────────────────────────────────────────────
PROBE_NODE_ID=test-local-01
ADMIN_TOKEN=change-me-admin
HTTP_PORT=8080

# ── ActiveMQ embedded nel monitor (gira sull'host) ────────────────────────────
# host.docker.internal risolve verso l'host su Mac e Windows automaticamente.
# Su Linux viene aggiunto come extra_host in docker-compose.test-local.yml.
BROKER_URL=tcp://host.docker.internal:61616
BROKER_USER=system
BROKER_PASSWORD=manager

# ── MySQL (gira sull'host, usato dal monitor) ─────────────────────────────────
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_DATABASE=concern
MYSQL_USER=concern
MYSQL_PASSWORD=concern
