# ══════════════════════════════════════════════════════════════════════════════
# Concern Probes Runtime — environment configuration
#
# Profiles available (pass to docker compose with --profile):
#   local-broker   → start ActiveMQ locally in this compose stack
#   local-mysql    → start MySQL locally in this compose stack
#
# If you DON'T activate a profile, set the connection address below
# so the probe runtime (and monitor) know where to connect.
#
# Examples:
#   docker compose --profile local-broker --profile local-mysql up
#   docker compose up                          (both external)
#   docker compose --profile local-broker up   (only broker local)
# ══════════════════════════════════════════════════════════════════════════════

# ── Physical node identity ─────────────────────────────────────────────────
PROBE_NODE_ID=local-dev-01

# ── Admin token for the probe UI / REST API ────────────────────────────────
ADMIN_TOKEN=change-me-admin

# ── HTTP port ──────────────────────────────────────────────────────────────
HTTP_PORT=8080

# ── ActiveMQ broker ───────────────────────────────────────────────────────
# Used when NOT running with --profile local-broker.
# When local-broker profile IS active, this is ignored (container uses
# the internal docker network address automatically).
BROKER_HOST=localhost
BROKER_PORT=61616
BROKER_URL=tcp://${BROKER_HOST}:${BROKER_PORT}
BROKER_USER=system
BROKER_PASSWORD=manager

# Local broker settings (used only with --profile local-broker)
LOCAL_BROKER_OPENWIRE_PORT=61616
LOCAL_BROKER_CONSOLE_PORT=8161

# ── MySQL ──────────────────────────────────────────────────────────────────
# Used by the Concern Monitoring Infrastructure (monitor side).
# The probe runtime itself does not connect to MySQL — these settings are
# here so a full local stack can be started from this single compose file.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=concern
MYSQL_USER=concern
MYSQL_PASSWORD=concern
MYSQL_ROOT_PASSWORD=rootpassword

# Local MySQL settings (used only with --profile local-mysql)
LOCAL_MYSQL_PORT=3306
